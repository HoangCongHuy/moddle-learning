{
    "name": "moodle/local_debugbar",
    "description": "Private Debugbar integration for Moodle administrators.",
    "type": "moodle-local",
    "require": {
        "php": ">=7.4",
        "php-debugbar/php-debugbar": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "local_debugbar\\": "classes/"
        }
    },
    "config": {
        "platform": {
            "php": "7.4.0"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
